# ===== Azure SQL Database =====
# Get these from: Azure Portal > SQL databases > FreelancerDB > Connection strings
DB_SERVER=freelancer-sql-server-yourname.database.windows.net
DB_NAME=FreelancerDB
DB_USER=sqladmin
DB_PASSWORD=your_sql_password_here
DB_PORT=1433

# ===== Azure Blob Storage =====
# Get from: Storage Account > Access keys > Connection string
AZURE_STORAGE_CONNECTION_STRING=your_blob_connection_string_here
AZURE_STORAGE_CONTAINER=project-files
# ===== Azure Function (Time Tracker) =====
# CalculateHours function — computes hours from start/end times
# Get the full URL (with code) from: Azure Portal > Function App > CalculateHours > Get Function URL
AZURE_FUNCTION_CALC_HOURS_URL=https://freelancer-timetracker-adityatalreja.azurewebsites.net/api/CalculateHours?code=your_function_key_here

# ===== App =====
PORT=8080
